{
  "name": "dreamcode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "bin": {
    "dreamcode": "packages/cli/dist/main.js"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm typecheck && pnpm test",
    "dev": "tsx --conditions=development packages/cli/src/main.ts",
    "dreamcode": "tsx --conditions=development packages/cli/src/main.ts",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^24.7.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
