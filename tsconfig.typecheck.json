{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "rootDir": ".",
    "tsBuildInfoFile": ".tmp/tsconfig.typecheck.tsbuildinfo"
