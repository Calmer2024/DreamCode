{
  "name": "@dreamcode/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "dreamcode": "dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/main.js"
    }
  },
  "scripts": {
    "build": "tsup src/main.ts --format esm --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@dreamcode/core": "workspace:*",
    "@dreamcode/models": "workspace:*",
    "@dreamcode/shared": "workspace:*",
    "@dreamcode/store": "workspace:*",
    "@dreamcode/tools": "workspace:*",
    "commander": "^14.0.1",
    "ink": "^7.1.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17"
  }
}
